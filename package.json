{
  "name": "ui-mcp",
  "version": "0.1.0",
  "description": "An MCP server that gives Claude Code access to elite UI patterns, components, and motion configs.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "ui-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    ".mcp.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w",
    "start": "node dist/server.js",
    "smoke": "npm run build && node dist/scripts/smoke-test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "ui",
    "react",
    "tailwind",
    "framer-motion",
    "animation"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fuse.js": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
